---
const { presentation } = Astro.props;
---
<aside class="rail">
  <section>
    <h2>Provenance</h2>
    <dl class="kv">
      <div><dt>Source</dt><dd><a href={presentation.sourceUrl}>{presentation.sourceLabel}</a><span class="doc-title">{presentation.provenance.source}</span></dd></div>
      <div><dt>Archived copy</dt><dd class="nw"><a href={presentation.sourceUrl}>capture</a> &middot; {presentation.eventDate}</dd></div>
      <div><dt>Record tier</dt><dd><span class="tier-chip">{presentation.tierLabel}</span></dd></div>
      <div><dt>Event date</dt><dd class="nw">{presentation.eventDate}</dd></div>
      <div><dt>Method</dt><dd><a href="/methodology">Methodology</a></dd></div>
    </dl>
  </section>
  <section>
    <h2>Record history</h2>
    <ol class="ledger">
      {presentation.history.map((entry) => <li class={entry.status === "Corrected" ? "event-corrected" : undefined}><span class="stamp">{entry.status} &middot; {entry.date}</span><p>{entry.text}</p></li>)}
    </ol>
  </section>
</aside>
