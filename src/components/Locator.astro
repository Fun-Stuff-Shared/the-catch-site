---
const { record, presentation } = Astro.props;
const statusClass = record.publication_status === "active" ? "loc-status-blue" : "loc-status-red";
const historyCount = presentation.history.length;
const displayStatus = presentation.previewOnly ? "PREVIEW" : record.publication_status.toUpperCase();
---
<div class="locator">
  <span>RECORD</span>
  <span>{presentation.tierLabel.toUpperCase()}</span>
  <span class={presentation.previewOnly ? "loc-status-blue" : statusClass}>{displayStatus}</span>
  {presentation.eventPath ? <a class="loc-event" href={presentation.eventPath}>EVENT: {presentation.eventTitle} &rarr;</a> : <span class="loc-event">EVENT: {presentation.eventTitle}</span>}
  {historyCount > 0 && <a class="loc-history" href={`/claims/${record.reader_slug}/history/`} title="Version history"><span class="h-glyph">&#8635;</span>HISTORY ({historyCount})</a>}
</div>
