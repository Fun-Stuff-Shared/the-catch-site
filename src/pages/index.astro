---
import BaseLayout from "../layouts/BaseLayout.astro";
import ArchiveNav from "../components/ArchiveNav.astro";
import { records } from "../lib/export.mjs";
import { archiveGroups } from "../lib/date-archive.mjs";
import { presentationFor } from "../lib/presentation.mjs";

const archive = archiveGroups(records);
---
<BaseLayout title="The Catch">
  <div slot="locator" class="locator"><span>RECORDS</span><span>PUBLIC RECORD</span></div>
  <div class="content">
    <main class="method-main">
      <h1>The Catch</h1>
      <p class="lede">Verified public record surface.</p>
      {records.length === 0 && (
        <p class="lede">
          The first records are in preparation. The <a href="/methodology">methodology</a> is
          published; every record will carry its source quote, verification status, and full
          correction history from day one.
        </p>
      )}
      <ArchiveNav archive={archive} />
      <ul class="matters-grid">
        {records.map((record) => {
          const presentation = presentationFor(record);
          return <li><a href={`/claims/${record.claim_id}`}><span class:list={["mt-status", presentation.previewOnly || record.publication_status === "active" ? "st-blue" : "st-red"]}>{presentation.previewOnly ? "preview" : record.publication_status}</span><span class="mt-title">{presentation.matterTitle}</span><span class="mt-finding">{presentation.findingLine}</span><span class="mt-meta">{presentation.eventDate} &middot; {presentation.tierLabel}</span></a></li>;
        })}
      </ul>
    </main>
  </div>
</BaseLayout>
