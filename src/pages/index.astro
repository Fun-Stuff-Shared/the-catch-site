---
import BaseLayout from "../layouts/BaseLayout.astro";
import { records } from "../lib/export.mjs";
import { presentationFor } from "../lib/presentation.mjs";
---
<BaseLayout title="The Catch">
  <div slot="locator" class="locator"><span>RECORDS</span><span>PUBLIC RECORD</span></div>
  <div class="content">
    <main class="method-main">
      <h1>The Catch</h1>
      <p class="lede">Verified public record surface.</p>
      <ul class="matters-grid">
        {records.map((record) => {
          const presentation = presentationFor(record);
          return <li><a href={`/claims/${record.claim_id}`}><span class:list={["mt-status", record.publication_status === "active" ? "st-blue" : "st-red"]}>{record.publication_status}</span><span class="mt-title">{presentation.matterTitle}</span><span class="mt-finding">{presentation.findingLine}</span><span class="mt-meta">{presentation.eventDate} &middot; {presentation.tierLabel}</span></a></li>;
        })}
      </ul>
    </main>
  </div>
</BaseLayout>
