---
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import Locator from "../../../../components/Locator.astro";
import { records } from "../../../../lib/export.mjs";
import { presentationFor } from "../../../../lib/presentation.mjs";

export function getStaticPaths() {
  return records.map((record) => ({ params: { id: record.claim_id }, props: { record } }));
}

const { record } = Astro.props;
const presentation = presentationFor(record);
---
<BaseLayout title={`Version history | ${presentation.matterTitle}`}>
  <Locator slot="locator" record={record} presentation={presentation} />
  <div class="content"><main class="method-main"><h1>Version history</h1><p class="lede">A dated ledger for this record.</p><ol class="ledger">{presentation.history.map((entry) => <li class={entry.status === "Corrected" ? "event-corrected" : undefined}><span class="stamp">{entry.status} &middot; {entry.date}</span><p>{entry.text}</p></li>)}</ol></main></div>
</BaseLayout>
